# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Demo login (local/staging only — omit or set false in production)
ENABLE_DEMO_LOGIN=true
DEMO_LOGIN_EMAIL=demo@example.com
DEMO_LOGIN_PASSWORD=DemoPass123!
# Fixed month for demo user when ?month= is missing (YYYY-MM; must match seeded data)
DEMO_DEFAULT_MONTH=2026-06
